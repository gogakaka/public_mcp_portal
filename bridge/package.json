{
  "name": "@umg/bridge",
  "version": "0.1.0",
  "description": "Universal MCP Gateway CLI bridge - stdio-to-SSE proxy for local IDE integration",
  "main": "dist/index.js",
  "bin": {
    "umg-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
