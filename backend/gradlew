#!/bin/sh

#
# Gradle 시작 스크립트 (POSIX 호환)
#
# Gradle Wrapper를 통해 프로젝트에서 지정한 Gradle 버전으로 빌드를 실행합니다.
# gradle/wrapper/gradle-wrapper.properties에 정의된 Gradle 배포본을
# 자동으로 다운로드하여 사용합니다.
#

##############################################################################
##
##  Gradle 시작 스크립트 (Unix 계열)
##
##############################################################################

# 심볼릭 링크를 따라가며 스크립트의 실제 위치를 찾습니다.
APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

# 운영체제별 지원 함수
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )         cygwin=true  ;;
  Darwin* )         darwin=true  ;;
  MINGW* )          msys=true    ;;
  NONSTOP* )        nonstop=true ;;
esac

# 이 스크립트의 실제 경로를 확인합니다 (심볼릭 링크 해제).
PRG="$0"
while [ -h "$PRG" ] ; do
    ls=$(ls -ld "$PRG")
    link=$(expr "$ls" : '.*-> \(.*\)$')
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=$(dirname "$PRG")"/$link"
    fi
done
SAVED="$(pwd)"
cd "$(dirname "$PRG")/" >/dev/null
APP_HOME="$(pwd -P)"
cd "$SAVED" >/dev/null

# JVM 기본 옵션 설정
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# JAVA_HOME이 설정되어 있으면 해당 경로에서 java 실행 파일을 사용합니다.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "오류: JAVA_HOME이 '$JAVA_HOME'으로 설정되어 있지만 '$JAVACMD'에서 java를 찾을 수 없습니다."
    fi
else
    JAVACMD="java"
    if ! command -v java >/dev/null 2>&1 ; then
        die "오류: JAVA_HOME이 설정되지 않았고 PATH에서 'java' 명령을 찾을 수 없습니다."
    fi
fi

# Gradle Wrapper JAR 파일 경로
CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

# Cygwin 환경 경로 변환
if "$cygwin" ; then
    APP_HOME=$(cygpath --path --mixed "$APP_HOME")
    CLASSPATH=$(cygpath --path --mixed "$CLASSPATH")
    JAVACMD=$(cygpath --unix "$JAVACMD")
fi

# 인자에 공백이 포함된 경우의 처리
# Wrapper JAR가 없는 경우에도 적절히 처리
if [ ! -f "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" ]; then
    echo "경고: Gradle Wrapper JAR 파일을 찾을 수 없습니다."
    echo "      'gradle wrapper' 명령을 실행하여 Wrapper를 생성하세요."
    echo ""
    echo "      또는 https://services.gradle.org/distributions/ 에서"
    echo "      gradle-wrapper.jar를 다운로드하여"
    echo "      $APP_HOME/gradle/wrapper/ 에 배치하세요."
    exit 1
fi

# Gradle Wrapper 실행
exec "$JAVACMD" \
    $DEFAULT_JVM_OPTS \
    $JAVA_OPTS \
    $GRADLE_OPTS \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
